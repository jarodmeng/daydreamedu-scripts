# Buddy Console backend — local secrets (copy to .env.local; never commit .env.local)
#
#   cp .env.local.example .env.local
#   # edit .env.local, then from repo root:
#   set -a && source ai_study_buddy/buddy_console/backend/.env.local && set +a
#   python3 -m uvicorn ai_study_buddy.buddy_console.backend.app:app --reload --port 8010
#
# Mint CURSOR_API_KEY: https://cursor.com/dashboard/integrations

# Review Workspace tutor chat (Cursor SDK local agent). Required when tutor-chat routes are enabled.
CURSOR_API_KEY=

# Optional: override context root (default: <repo>/ai_study_buddy/context)
# AI_STUDY_BUDDY_CONTEXT_ROOT=

# Marking / amendments / review notes for tutor chat (and Review Workspace) read from study_buddy.db
# by default (LEARNING_DB_ENABLE_READS=1, LEARNING_DB_READ_FALLBACK_FILESYSTEM=0). Override only if needed:
# STUDY_BUDDY_DB_PATH=/path/to/study_buddy.db
# LEARNING_DB_ENABLE_READS=1
# LEARNING_DB_READ_FALLBACK_FILESYSTEM=0

# Optional: expose GET …/tutor-chat/context-preview (no inference; inspect assembled bundle)
# BUDDY_CONSOLE_TUTOR_CHAT_DEBUG=1
# BUDDY_CONSOLE_DISABLE_TUTOR_CHAT=1
