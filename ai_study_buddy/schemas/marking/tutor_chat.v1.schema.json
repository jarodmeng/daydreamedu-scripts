{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daydreamedu.local/schemas/tutor_chat.v1.schema.json",
  "title": "tutor_chat.v1",
  "type": "object",
  "required": [
    "schema_version",
    "attempt_id",
    "result_id",
    "student_id",
    "subject_context",
    "marking_artifact_stem",
    "session_id",
    "created_at",
    "updated_at",
    "messages",
    "context_snapshot"
  ],
  "properties": {
    "schema_version": {
      "const": "tutor_chat.v1"
    },
    "attempt_id": { "type": "string", "minLength": 1 },
    "result_id": { "type": "string", "minLength": 1 },
    "student_id": { "type": "string", "minLength": 1 },
    "subject_context": { "type": "string", "minLength": 1 },
    "marking_artifact_stem": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "cursor_agent_id": { "type": ["string", "null"] },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content", "at"],
        "properties": {
          "role": { "enum": ["student", "assistant"] },
          "content": { "type": "string" },
          "at": { "type": "string", "minLength": 1 },
          "model": { "type": "string" },
          "runtime": { "type": "string" },
          "run_id": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "context_snapshot": {
      "type": "object",
      "required": ["marking_result_path", "resolved_question_fingerprint"],
      "properties": {
        "marking_result_path": { "type": "string", "minLength": 1 },
        "amendment_updated_at": { "type": ["string", "null"] },
        "review_state_updated_at": { "type": ["string", "null"] },
        "resolved_question_fingerprint": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
