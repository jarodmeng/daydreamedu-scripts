{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-root-pdf-browser",
      "type": "shell",
      "command": "python3 -m ai_study_buddy.root_pdf_browser.spawn_background",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "start-root-pdf-browser (attached)",
      "type": "shell",
      "command": "python3 -m ai_study_buddy.root_pdf_browser.serve",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "root-pdf-browser",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Root PDF browser at",
          "endsPattern": "^--- root-pdf-browser: ready"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    }
  ]
}
